PARSER_BEGIN(Lugosi)
import java.io.*;
public class Lugosi {
  public static void main(String args[]) throws ParseException,IOException {
    if (args.length == 0) {
      System.err.println("Uso: java Lugosi arquivo.rs");
      return;
    }
    Lugosi analisador = new Lugosi(new FileInputStream(args[0]));
    analisador.Lugosi();
  }
}
PARSER_END(Lugosi)
SKIP : { " " | "\t" | "\n" | "\r" }
TOKEN : {
  <FN: "fn"> | <LET: "let"> | <PRINTLN: "println!"> | <F32: "f32"> | <I32: "i32"> | <BOOL_TYPE: "bool">
| <ACHAVES: "{"> | <FCHAVES: "}"> | <SEMI: ";"> | <COLON: ":"> | <ASSIGN: "="> | <APARENTESES: "("> | <FPARENTESES: ")">
| <IF: "if"> | <WHILE: "while"> | <RETURN: "return"> | <TRUE: "true"> | <FALSE: "false">
| <SUM: "+"> | <SUB: "-"> | <MULT: "*"> | <DIV: "/"> | <AND: "&&"> | <OR: "||">
| <MENOR: "<"> | <MAIOR: ">"> | <IGUAL: "=="> | <VIRGULA: ",">
| <NUM: ( ["-"] )? ( ["0"-"9"] )+ ( ["."] ( ["0"-"9"] )+ )? ( ["e","E"] ( ["-"] )? ( ["0"-"9"] )+ )?>
| <ID: ( ["a"-"z","A"-"Z","_"] ) ( ["a"-"z","A"-"Z","0"-"9","_"] )*>
}
void Lugosi () : {Token t;} {
(
  <FN> { System.out.println("Palavra reservada: fn"); }
| <LET> { System.out.println("Palavra reservada: let"); }
| <PRINTLN> { System.out.println("Palavra reservada: println!"); }
| <F32> { System.out.println("Palavra reservada: f32"); }
| <I32> { System.out.println("Palavra reservada: i32"); }
| <BOOL_TYPE> { System.out.println("Palavra reservada: bool"); }
| <ACHAVES> { System.out.println("Abre Chaves: {"); }
| <FCHAVES> { System.out.println("Fecha chaves: }"); }
| <APARENTESES> { System.out.println("Abre parênteses: ("); }
| <FPARENTESES> { System.out.println("Fecha parênteses: )"); }
| <COLON> { System.out.println("Dois pontos: :"); }
| <SEMI> { System.out.println("Ponto e virgula: ;"); }
| <ASSIGN> { System.out.println("Atribuição: ="); }
| <IF> { System.out.println("Palavra reservada: if"); }
| <WHILE> { System.out.println("Palavra reservada: while"); }
| <RETURN> { System.out.println("Palavra reservada: return"); }
| <TRUE> { System.out.println("Valor lógico: true"); }
| <FALSE> { System.out.println("Valor lógico: false"); }
| <SUM> { System.out.println("Soma: +"); }
| <SUB> { System.out.println("Subtração: -"); }
| <MULT> { System.out.println("Multiplicação: *"); }
| <DIV> { System.out.println("Divisão: /"); }
| <AND> { System.out.println("Função lógica: &&"); }
| <OR> { System.out.println("Função lógica: ||"); }
| <MENOR> { System.out.println("Comparação: <"); }
| <MAIOR> { System.out.println("Comparação: >"); }
| <IGUAL> { System.out.println("Comparação: =="); }
| <VIRGULA> { System.out.println("Vírgula: ,"); }
